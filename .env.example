# ONYX runtime configuration

# --- Agent ---
ONYX_AGENT_PORT=4311
ONYX_WORKSPACE_ROOT=./
ONYX_DB_PATH=./agent/data/onyx.db

# --- Intelligence layer ---
# Set either or both; ONYX auto-routes via the Blackout Protocol.
MISTRAL_API_KEY=
MISTRAL_MODEL=codestral-latest
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=open-codestral-7b

# --- Blackout protocol ---
ONYX_BLACKOUT_PROBE=https://api.mistral.ai/v1/models
ONYX_BLACKOUT_INTERVAL_MS=5000

# --- Frontend ---
NEXT_PUBLIC_ONYX_AGENT_WS=ws://127.0.0.1:4311/stream
NEXT_PUBLIC_ONYX_AGENT_HTTP=http://127.0.0.1:4311

# --- GitHub OAuth (optional) ---
# Create an OAuth app at https://github.com/settings/developers
GITHUB_ID=
GITHUB_SECRET=
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000
