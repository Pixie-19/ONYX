    },
    {
      "page": "/connect",
      "regex": "^/connect(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/connect(?:/)?$"
    },
    {
      "page": "/demo",
      "regex": "^/demo(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/demo(?:/)?$"
    },
    {
      "page": "/events",
