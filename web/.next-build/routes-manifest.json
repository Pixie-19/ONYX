      "namedRegex": "^/events(?:/)?$"
    },
    {
      "page": "/graph",
      "regex": "^/graph(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/graph(?:/)?$"
    },
    {
      "page": "/infrastructure",
      "regex": "^/infrastructure(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/infrastructure(?:/)?$"
    },
    {
      "page": "/intelligence",
      "regex": "^/intelligence(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/intelligence(?:/)?$"
    },
    {
      "page": "/replay",
      "regex": "^/replay(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/replay(?:/)?$"
    },
    {
      "page": "/settings",
      "regex": "^/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/settings(?:/)?$"
    },
    {
      "page": "/sql",
      "regex": "^/sql(?:/)?$",
      "routeKeys": {},
