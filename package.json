{
  "name": "onyx",
  "version": "0.1.0",
  "private": true,
  "description": "ONYX — Autonomous Execution Intelligence Infrastructure",
  "workspaces": [
    "agent",
    "web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:agent dev:web",
    "dev:agent": "npm --workspace agent run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm-run-all build:agent build:web",
    "build:agent": "npm --workspace agent run build",
    "build:web": "npm --workspace web run build",
    "seed": "npm --workspace agent run seed",
    "demo": "npm --workspace agent run demo"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
